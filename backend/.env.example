# TMDB API key (v3 — same one as the frontend, but now stored server-side only)
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Secret key for signing JWT tokens — generate a strong random string
# e.g. python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string

# Token expiry in minutes (default 60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite database file path
DATABASE_URL=sqlite:///./reel.db

# CORS — set to your frontend dev URL (or * for local dev)
ALLOWED_ORIGINS=http://localhost:5173
